{
  "id": "react-grab-onboarding",
  "title": "React Grab Codebase Tour",
  "description": "A guided walkthrough of the React Grab monorepo - select context for coding agents directly from your website",
  "version": "1.0.0",
  "steps": [
    {
      "id": "overview",
      "title": "Welcome to React Grab",
      "description": "Point at any UI element, press Cmd+C, and get the file name, React component, and HTML source - making coding agents run up to 3x faster. This monorepo uses pnpm workspaces with Turborepo across 20+ packages.",
      "colorMode": "fileTypes"
    },
    {
      "id": "core-library",
      "title": "Core Library",
      "description": "The SolidJS-based overlay that powers element selection, clipboard handling, and the plugin system. Core engine in src/core/, UI components in src/components/, and helpers in src/utils/.",
      "focusDirectory": "packages/react-grab/src",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "core-engine",
          "name": "Core Engine",
          "color": "#3b82f6",
          "items": [
            { "path": "packages/react-grab/src/core", "type": "directory" },
            { "path": "packages/react-grab/src/index.ts", "type": "file" },
            { "path": "packages/react-grab/src/types.ts", "type": "file" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        },
        {
          "id": "ui-components",
          "name": "UI Components",
          "color": "#10b981",
          "items": [
            { "path": "packages/react-grab/src/components", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        },
        {
          "id": "utilities",
          "name": "Utilities",
          "color": "#f59e0b",
          "items": [
            { "path": "packages/react-grab/src/utils", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        }
      ]
    },
    {
      "id": "core-internals",
      "title": "Selection & Plugins",
      "description": "Element selection, keyboard handling, and clipboard ops live here. Built-in plugins (copy, open, comment) extend functionality via the plugin registry. The agent/ subdirectory manages AI agent sessions.",
      "focusDirectory": "packages/react-grab/src/core",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "selection-flow",
          "name": "Selection Flow",
          "color": "#8b5cf6",
          "items": [
            { "path": "packages/react-grab/src/core/context.ts", "type": "file" },
            { "path": "packages/react-grab/src/core/events.ts", "type": "file" },
            { "path": "packages/react-grab/src/core/keyboard-handlers.ts", "type": "file" },
            { "path": "packages/react-grab/src/core/copy.ts", "type": "file" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        },
        {
          "id": "plugin-system",
          "name": "Plugin System",
          "color": "#ec4899",
          "items": [
            { "path": "packages/react-grab/src/core/plugin-registry.ts", "type": "file" },
            { "path": "packages/react-grab/src/core/plugins", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        }
      ]
    },
    {
      "id": "cli-package",
      "title": "CLI Setup Tool",
      "description": "Powers 'npx grab@latest init' - detects your framework, installs react-grab, and injects the correct script. Commands: init, add (MCP integration), remove, and configure.",
      "focusDirectory": "packages/cli/src",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "cli-commands",
          "name": "CLI Commands",
          "color": "#06b6d4",
          "items": [
            { "path": "packages/cli/src/cli.ts", "type": "file" },
            { "path": "packages/cli/src/commands", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        },
        {
          "id": "cli-utils",
          "name": "CLI Utilities",
          "color": "#f97316",
          "items": [
            { "path": "packages/cli/src/utils", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        }
      ]
    },
    {
      "id": "agent-providers",
      "title": "Agent Providers",
      "description": "Nine provider packages for Cursor, Claude Code, Copilot, Codex, Gemini, Amp, Droid, OpenCode, and Ami. Each follows a consistent client/server/handler pattern.",
      "focusDirectory": "packages",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "providers",
          "name": "Agent Providers",
          "color": "#a855f7",
          "items": [
            { "path": "packages/provider-cursor", "type": "directory" },
            { "path": "packages/provider-claude-code", "type": "directory" },
            { "path": "packages/provider-copilot", "type": "directory" },
            { "path": "packages/provider-codex", "type": "directory" },
            { "path": "packages/provider-gemini", "type": "directory" },
            { "path": "packages/provider-amp", "type": "directory" },
            { "path": "packages/provider-droid", "type": "directory" },
            { "path": "packages/provider-opencode", "type": "directory" },
            { "path": "packages/provider-ami", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        }
      ]
    },
    {
      "id": "relay-and-mcp",
      "title": "Relay & MCP",
      "description": "The relay package is the WebSocket bridge between browser and coding agents. The MCP package exposes React Grab as a Model Context Protocol server for programmatic access.",
      "focusDirectory": "packages",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "relay-layer",
          "name": "Relay (WebSocket Bridge)",
          "color": "#14b8a6",
          "items": [
            { "path": "packages/relay", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        },
        {
          "id": "mcp-layer",
          "name": "MCP Server",
          "color": "#f43f5e",
          "items": [
            { "path": "packages/mcp", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        },
        {
          "id": "shared-utils",
          "name": "Shared Utilities",
          "color": "#eab308",
          "items": [
            { "path": "packages/utils", "type": "directory" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        }
      ]
    },
    {
      "id": "web-extension",
      "title": "Browser Extension",
      "description": "Bundles React Grab as a Chrome extension for any website without code changes. Uses a service worker, content script bridge, and Manifest V3.",
      "focusDirectory": "packages/web-extension/src",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "extension-core",
          "name": "Extension Core",
          "color": "#6366f1",
          "items": [
            { "path": "packages/web-extension/src/background", "type": "directory" },
            { "path": "packages/web-extension/src/content", "type": "directory" },
            { "path": "packages/web-extension/src/manifest.json", "type": "file" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        }
      ]
    },
    {
      "id": "infra-and-config",
      "title": "Monorepo Infrastructure",
      "description": "pnpm workspaces with Turborepo for builds, Changesets for versioning, and Vercel for deployment. AGENTS.md defines coding conventions.",
      "focusDirectory": "",
      "colorMode": "fileTypes",
      "highlightLayers": [
        {
          "id": "build-config",
          "name": "Build & Deploy Config",
          "color": "#64748b",
          "items": [
            { "path": "turbo.json", "type": "file" },
            { "path": "pnpm-workspace.yaml", "type": "file" },
            { "path": "vercel.json", "type": "file" },
            { "path": "package.json", "type": "file" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        },
        {
          "id": "dev-docs",
          "name": "Developer Docs",
          "color": "#22c55e",
          "items": [
            { "path": "AGENTS.md", "type": "file" },
            { "path": "CONTRIBUTING.md", "type": "file" },
            { "path": "README.md", "type": "file" }
          ],
          "opacity": 0.7,
          "renderStrategy": "border"
        }
      ]
    }
  ]
}
